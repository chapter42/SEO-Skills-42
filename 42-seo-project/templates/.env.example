# SEO Project Configuration
# Generated by /seo-project init
# Location: .seo-project/<domain>/.env

# === Project ===
SITE_URL=
DOMAIN=
BUSINESS_TYPE=
LANGUAGE=

# === Screaming Frog ===
SF_AVAILABLE=                        # auto-detected (true/false)
SF_EXPORT_DIR=                       # default: .seo-project/<domain>/exports
# SF_CONFIG=                         # optional: path to custom .seospider profile

# === Data APIs (optional — skills degrade gracefully without these) ===
# DataForSEO — ~$0.002/query — https://dataforseo.com
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# Google Search Console — https://console.cloud.google.com
GSC_SERVICE_ACCOUNT_PATH=

# Ahrefs — or use Ahrefs MCP server instead
AHREFS_API_KEY=

# SEMRush — or use SEMRush MCP server instead
SEMRUSH_API_KEY=

# === Embedding Provider (for keyword-mapper, passage-analyzer, near-duplicates) ===
# Choose one: openai | gemini | anthropic | ollama
EMBEDDING_PROVIDER=
OPENAI_API_KEY=
GOOGLE_API_KEY=
# OLLAMA_HOST=http://localhost:11434  # if using local Ollama
